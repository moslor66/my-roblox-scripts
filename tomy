-- [2. LOGIKA DRAGGING] -------------------------------------------------------
local dragging, dragInput, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- [3. FIX: SISTEM BLACKLIST & DETEKSI] ---------------------------------------
-- Tabel ini akan menyimpan koin mana saja yang baru disentuh
local ignoreTokens = {}

local function GetNearestNumberToken()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local charPos = character.HumanoidRootPart.Position
    local nearestToken = nil
    local shortestDistance = math.huge

    pcall(function()
        for _, obj in pairs(workspace:GetDescendants()) do
            -- Cek apakah nama objek itu angka DAN belum masuk daftar hitam (ignoreTokens)
            if tonumber(obj.Name) ~= nil and not ignoreTokens[obj] then
                if obj:IsA("BasePart") or obj:IsA("Model") then
                    local targetPart = obj:IsA("Model") and obj.PrimaryPart or obj
                    
                    if targetPart and targetPart:IsA("BasePart") then
                        -- FIX TAMBAHAN: Jangan ambil koin yang tembus pandang / hilang
                        if targetPart.Transparency < 1 then
                            local distance = (charPos - targetPart.Position).Magnitude
                            if distance < shortestDistance then
                                shortestDistance = distance
                                nearestToken = targetPart
                            end
                        end
                    end
                end
            end
        end
    end)
    
    return nearestToken
end

-- [4. LOGIKA AUTO COLLECT UTAMA] ---------------------------------------------
local function HandleAutoCollect()
    if isAutoCollectOn then
        farmConnection = task.spawn(function()
            while isAutoCollectOn do
                local targetToken = GetNearestNumberToken()
                local character = LocalPlayer.Character
                
                if targetToken and character and character:FindFirstChild("HumanoidRootPart") then
                    local hrp = character.HumanoidRootPart
                    hrp.CFrame = targetToken.CFrame

                    if firetouchinterest then
                        firetouchinterest(hrp, targetToken, 0)
                        task.wait(0.01)
                        firetouchinterest(hrp, targetToken, 1)
                    end
                    
                    -- [ INI KUNCI FIX-NYA ]
                    -- Masukkan token ke daftar hitam agar dilewati pada loop berikutnya
                    ignoreTokens[targetToken] = true
                    
                    -- Hapus token secara paksa di layar kita agar pasti cari yang lain
                    if targetToken.Parent then targetToken:Destroy() end
                    
                    -- Hapus dari daftar hitam setelah 3 detik (berjaga-jaga jika gamenya me-respawn koinnya)
                    task.delay(3, function()
                        ignoreTokens[targetToken] = nil
                    end)

                    task.wait(Settings.TeleportDelay)
                else
                    task.wait(Settings.WaitIfEmpty)
                end
            end
        end)
    else
        if farmConnection then
            task.cancel(farmConnection)
            farmConnection = nil
        end
    end
end

